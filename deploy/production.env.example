# Copy this file to deploy/production.env on the server.
# Do not commit deploy/production.env.

SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=lark_session
SESSION_MAX_AGE_SECONDS=2592000

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_API_BASE=https://open.feishu.cn/open-apis
# websocket = official SDK long connection; webhook = old public callback; both = both receivers.
FEISHU_EVENT_MODE=websocket

# Optional if you access the API directly from another origin.
# For same-origin Nginx access, this usually does not matter.
# CORS_ORIGINS=["http://154.64.230.23"]
