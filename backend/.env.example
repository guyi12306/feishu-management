# Copy this file to .env and change values before running in production.

# ────── App ──────
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true

# Change this to a long random string. It signs sessions and encrypts local secrets.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=lark_session
SESSION_MAX_AGE_SECONDS=2592000

# SQLite path, relative to backend/.
DATABASE_PATH=./data/app.db

# Default account created on first startup.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# ────── LLM ──────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ────── Feishu/Lark ──────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_API_BASE=https://open.feishu.cn/open-apis
